{
    "schema_version":  "1.0",
    "project_id":  "DEMO_PHOTO",
    "description":  "Demonstrates deterministic LLM responses using multiple gates",
    "g8son_gates":  [
                        "g8son/photosynthesis.g8son",
                        "g8son/photosynthesis2.g8son"
                    ],
    "gst_context":  "gst/photosynthesis.gst",
    "qson_audit_log":  "qson/photosynthesis.qson",
